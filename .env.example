# Multi-Agent Research Lab - Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# LLM PROVIDER API KEYS (at least one required)
# =============================================================================
OPENAI_API_KEY=your-openai-key-here
ANTHROPIC_API_KEY=your-anthropic-key-here

# Optional: LiteLLM for multi-provider support
# LITELLM_MASTER_KEY=your-litellm-master-key

# =============================================================================
# EXTERNAL SEARCH APIs (at least one required for web research)
# =============================================================================
TAVILY_API_KEY=your-tavily-key-here
SERPER_API_KEY=your-serper-key-here

# Optional: Google Custom Search
# GOOGLE_CSE_ID=your-cse-id
# GOOGLE_API_KEY=your-google-api-key

# =============================================================================
# ACADEMIC APIs
# =============================================================================
# arXiv doesn't require API key (public API)
# Optional: Semantic Scholar for citations
# SEMANTIC_SCHOLAR_API_KEY=your-semantic-scholar-key

# =============================================================================
# DATABASE CONNECTIONS
# =============================================================================

# Neo4j Knowledge Graph
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme-strong-password
NEO4J_DATABASE=neo4j

# ChromaDB Vector Store (uses local persistence by default)
# For remote ChromaDB:
# CHROMA_HOST=localhost
# CHROMA_PORT=8000
# CHROMA_TENANT=default
# CHROMA_DATABASE=default

# Redis (Celery broker + cache)
REDIS_URL=redis://localhost:6379/0

# SQLite (run history) - uses local file by default
# SQLITE_DB_PATH=data/history.db

# =============================================================================
# OBSERVABILITY
# =============================================================================

# Langfuse (LLM tracing & evaluation)
LANGFUSE_PUBLIC_KEY=your-langfuse-public-key
LANGFUSE_SECRET_KEY=your-langfuse-secret-key
LANGFUSE_HOST=http://localhost:3000
NEXTAUTH_SECRET=changeme-in-production
LANGFUSE_SALT=changeme-in-production
LANGFUSE_DB_PASSWORD=changeme-strong-password

# Grafana
GRAFANA_PASSWORD=changeme-strong-password

# Phoenix (Evaluation)
# PHOENIX_API_KEY=your-phoenix-key
# PHOENIX_ENDPOINT=http://localhost:6006

# Sentry (Error tracking)
# SENTRY_DSN=your-sentry-dsn
# SENTRY_ENVIRONMENT=development

# Prometheus metrics (enabled by default)
# PROMETHEUS_MULTIPROC_DIR=/tmp/prometheus

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================

# Model routing (agent_role: model_name)
# Format: JSON string or set via config.py
# PI=GPT-4o, Researchers=GPT-4o-mini, Analyst=GPT-4o, Critic=GPT-4o, Writer=Claude-3.5-Sonnet
MODEL_PI=gpt-4o
MODEL_RESEARCHER_A=gpt-4o-mini
MODEL_RESEARCHER_B=gpt-4o-mini
MODEL_RESEARCHER_C=gpt-4o-mini
MODEL_ANALYST=gpt-4o
MODEL_CRITIC=gpt-4o
MODEL_WRITER=claude-3-5-sonnet-20241022

# Quality thresholds
QUALITY_THRESHOLD=8.0
HARD_GATE_THRESHOLD=6.0
MAX_ITERATIONS=3
TOKEN_BUDGET_PER_RUN=200000

# CrewAI Flow settings
FLOW_MAX_RETRIES=2
FLOW_TIMEOUT_SECONDS=300

# Memory settings
CHROMA_PERSIST_DIR=data/knowledge_base
CHROMA_COLLECTION_NAME=research_findings
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# Knowledge Graph settings
KG_ENTITY_EXTRACTION_MODEL=gpt-4o-mini
KG_RELATION_EXTRACTION_MODEL=gpt-4o-mini

# API settings
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_CORS_ORIGINS=["http://localhost:3000", "http://localhost:8501"]

# Streamlit settings
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0

# Celery settings
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_ACCEPT_CONTENT=["json"]
CELERY_TIMEZONE=UTC
CELERY_ENABLE_UTC=true

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=data/logs/app.log

# Security
SECRET_KEY=changeme-generate-with-python-m secrets-token-urlsafe-64
ENCRYPTION_KEY=changeme-generate-with-python-m secrets-token-urlsafe-32
# SECURITY_ALLOWED_DOMAINS=["example.com", "trusted.org"]  # JSON array of allowed domains for URL validation

# Local LLM (Ollama) - optional
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# Feature flags
ENABLE_LANGFUSE=true
ENABLE_PHOENIX=false
ENABLE_PROMETHEUS=true
ENABLE_LOCAL_LLM=false
ENABLE_HUMAN_IN_LOOP=false